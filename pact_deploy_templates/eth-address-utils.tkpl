codeFile: ../pact_target/utils/eth-address-utils.pact

meta:
  chainId: "{{chain}}"
  sender: "{{gas-payer}}"
  gasLimit: 80000
  gasPrice: 0.00000001
  ttl: 86400

networkId: {{network}}
signers:
  - public: {{gas-payer-key}}
    caps:
      - name: coin.GAS
        args: []

  - public: {{admin-key-a}}
    caps: []
