(begin-tx)
(module test-ns GOVERNANCE
  (defcap GOVERNANCE () true)
  (defconst NAMESPACE_GUARD (create-user-guard (succeed)))
  (defun succeed () true)
)

(define-namespace "NAMESPACE" test-ns.NAMESPACE_GUARD test-ns.NAMESPACE_GUARD)
(commit-tx)


(begin-tx)
(namespace "NAMESPACE")
(load "eth-address-utils.pact")

(commit-tx)


(begin-tx)
(use NAMESPACE.eth-address-utils)

; Test with 0
(expect "0x00 address" "AAAAAAAAAAAAAAAAAAAAAAAAAAAA" (eth-address-to-b64 "00"))
(expect "0x00 address" "AAAAAAAAAAAAAAAAAAAAAAAAAAAA" (eth-address-to-b64 "0x00"))

; Text with Ones
(expect "0xff...ff address" "____________________________" (eth-address-to-b64 "FFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFF"))
(expect "0xff...ff address" "____________________________" (eth-address-to-b64 "0xFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFF"))


; Some Random Tests
(expect "A real address" "0xbf7c39037835d1b629c8a7c34424b90b60d62686" (b64-to-eth-address true "AAAAAAAAAAAAAAAAv3w5A3g10bYpyKfDRCS5C2DWJoY"))

(expect "A real address" "0xd2a199622a2bf1e1ede396f47ef1aedab5e2a6cd" (b64-to-eth-address true "AAAAAAAAAAAAAAAA0qGZYior8eHt45b0fvGu2rXips0"))

; Do some roundtrips

(expect "Roundtrip 0" "0x0000000000000000000000000000000000000000" (b64-to-eth-address true (eth-address-to-b64 "0000000000000000000000000000000000000000")))
(expect "Roundtrip ff..ff" "0xffffffffffffffffffffffffffffffffffffffff" (b64-to-eth-address true (eth-address-to-b64 "0xffffffffffffffffffffffffffffffffffffffff")))

; Roundtrip 1000 random addressess
; Note roundtrip works with lowercase only addresses (not ERC-55)
(expect "Rand Rountrip" "0x27d63fff42ae296418d2373234fff3758ac1da52" (b64-to-eth-address true (eth-address-to-b64 "0x27d63fff42ae296418d2373234fff3758ac1da52")))
