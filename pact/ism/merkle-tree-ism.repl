
(load "../utils/init-key-const.repl")

(begin-tx)
(env-data { "init": true })
(env-sigs [ { "key": bridge-keys.bridge, "caps": [] } ])
(load "merkle-tree-ism.pact")
(commit-tx)
(print "\nLoaded Merkle Tree ISM")

(begin-tx)
(namespace "NAMESPACE")
(env-sigs [ { "key": bridge-keys.bridge, "caps": [ (merkle-tree-ism.ONLY_ADMIN) ] } ])
(merkle-tree-ism.initialize ["alice" "charly"] 1)
(commit-tx)

;; validators-and-threshold
(begin-tx)
(namespace "NAMESPACE")
(expect "Correct validators and threshold" (merkle-tree-ism.validators-and-threshold data.message) {"threshold": 1,"validators": ["alice" "charly"]} )
(commit-tx)

;; get-validators
(begin-tx)
(namespace "NAMESPACE")
(expect "Correct validators" (merkle-tree-ism.get-validators data.message) ["alice" "charly"] )
(commit-tx)

;; get-threshold
(begin-tx)
(namespace "NAMESPACE")
(expect "Correct threshold" (merkle-tree-ism.get-threshold data.message) 1 )
(commit-tx)

;; add-validator ;; success
(begin-tx)
(namespace "NAMESPACE")
(env-sigs [ { "key": bridge-keys.bridge, "caps": [ (merkle-tree-ism.ONLY_ADMIN) ] } ])
(merkle-tree-ism.add-validator "bob")
(expect "Correct validators and threshold" (merkle-tree-ism.validators-and-threshold data.message) {"threshold": 1,"validators": ["alice" "charly" "bob"]} )
(commit-tx)

;; add-validator ;; fail wrong access
(begin-tx)
(namespace "NAMESPACE")
(env-sigs [ { "key": bridge-keys.alice, "caps": [] } ])
(expect-failure "Add validator wrong access" (merkle-tree-ism.add-validator "dave"))
(expect "Correct validators and threshold" (merkle-tree-ism.validators-and-threshold data.message) {"threshold": 1,"validators": ["alice" "charly" "bob"]} )
(commit-tx)

;; remove-validator ;; success
(begin-tx)
(namespace "NAMESPACE")
(env-sigs [ { "key": bridge-keys.bridge, "caps": [ (merkle-tree-ism.ONLY_ADMIN) ] } ])
(merkle-tree-ism.remove-validator "bob")
(expect "Correct validators and threshold after removing bob" (merkle-tree-ism.validators-and-threshold data.message) {"threshold": 1,"validators": ["alice" "charly"]} )
(commit-tx)

;; remove-validator ;; fail wrong access
(begin-tx)
(namespace "NAMESPACE")
(env-sigs [ { "key": bridge-keys.alice, "caps": [] } ])
(expect-failure "Remove validator wrong access" (merkle-tree-ism.remove-validator "alice"))
(expect "Correct validators and threshold" (merkle-tree-ism.validators-and-threshold data.message) {"threshold": 1,"validators": ["alice" "charly"]} )
(commit-tx)


;; set-threshold ;; fail wrong access
(begin-tx)
(namespace "NAMESPACE")
(env-sigs [ { "key": bridge-keys.alice, "caps": [] } ])
(expect-failure "Set-threshold" (merkle-tree-ism.set-threshold 1))
(expect "Correct validators and threshold" (merkle-tree-ism.validators-and-threshold data.message) {"threshold": 1,"validators": ["alice" "charly" ]} )
(commit-tx)

;; set-threshold ;; bad threshikd
(begin-tx)
(namespace "NAMESPACE")
(env-sigs [ { "key": bridge-keys.bridge, "caps": [ (merkle-tree-ism.ONLY_ADMIN) ] } ])
(expect-failure "Set-threshold" "Invalid threshold" (merkle-tree-ism.set-threshold 0))
(expect "Correct validators and threshold" (merkle-tree-ism.validators-and-threshold data.message) {"threshold": 1,"validators": ["alice" "charly" ]} )
(commit-tx)


;; set-threshold ;; bad threshikd
(begin-tx)
(namespace "NAMESPACE")
(env-sigs [ { "key": bridge-keys.bridge, "caps": [ (merkle-tree-ism.ONLY_ADMIN) ] } ])
(expect-failure "Set-threshold" "Invalid threshold" (merkle-tree-ism.set-threshold 10))
(expect "Correct validators and threshold" (merkle-tree-ism.validators-and-threshold data.message) {"threshold": 1,"validators": ["alice" "charly" ]} )
(commit-tx)


;; set-threshold ;; success
(begin-tx)
(namespace "NAMESPACE")
(env-sigs [ { "key": bridge-keys.bridge, "caps": [ (merkle-tree-ism.ONLY_ADMIN) ] } ])
(merkle-tree-ism.set-threshold 2)
(expect "Correct validators and threshold" (merkle-tree-ism.validators-and-threshold data.message) {"threshold": 2,"validators": ["alice" "charly" ]} )
(commit-tx)
